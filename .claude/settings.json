{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ashagent/adapters/claude_code/sessionstart.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ashagent/adapters/claude_code/pretooluse.py"
          }
        ]
      }
    ]
  }
}
